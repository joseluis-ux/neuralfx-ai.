        function calculateBotMetrics() {
            const hasMA = nodes.some(n => n.type === 'ma');
            const hasRSI = nodes.some(n => n.type === 'rsi');
            const hasAI = nodes.some(n => ['qlearning', 'neuralnet', 'randomForest'].includes(n.type));
            const hasScalp = nodes.some(n => n.type === 'patternScalp');
            const hasPropFirm = nodes.some(n => n.type === 'propFirmRisk');
            
            return {
                robustez: hasAI ? 85 : hasMA ? 78 : 65,
                complejidad: Math.min(nodes.length * 8, 95),
                tendencia: hasMA ? 82 : hasRSI ? 45 : 60,
                riesgo: hasPropFirm ? 35 : hasScalp ? 55 : 45,
                frecuencia: hasScalp ? 90 : hasRSI ? 70 : 50
            };
        }

