        // API Functions
        function loadApiConfig() {
            const saved = localStorage.getItem('neuralfx_api_config');
            if (saved) {
                apiConfig = JSON.parse(saved);
                document.getElementById('apiProvider').value = apiConfig.provider;
                document.getElementById('apiKey').value = apiConfig.key;
                if (apiConfig.provider !== 'local' && apiConfig.key) {
                    initializeAI();
                } else {
                    initializeLocal();
                }
            }
        }

        function saveApiConfig() {
            apiConfig.provider = document.getElementById('apiProvider').value;
            apiConfig.key = document.getElementById('apiKey').value.trim();
            
            if (apiConfig.provider !== 'local' && !apiConfig.key) {
                alert('Debes ingresar una API key o seleccionar "Modo Local"');
                return;
            }
            
            switch(apiConfig.provider) {
                case 'openai': apiConfig.endpoint = 'https://api.openai.com/v1/chat/completions'; break;
                case 'gemini': apiConfig.endpoint = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent'; break;
                case 'anthropic': apiConfig.endpoint = 'https://api.anthropic.com/v1/messages'; break;
                case 'local': apiConfig.endpoint = ''; break;
            }
            
            localStorage.setItem('neuralfx_api_config', JSON.stringify(apiConfig));
            document.getElementById('apiModal').classList.add('hidden');
            
            if (apiConfig.provider === 'local') {
                initializeLocal();
            } else {
                initializeAI();
            }
        }

