        function updateRadarChart() {
            const ctx = document.getElementById('radarChart').getContext('2d');
            
            // Calcular métricas basadas en nodos
            const metrics = calculateBotMetrics();
            
            document.getElementById('robustezValue').textContent = metrics.robustez + '%';
            document.getElementById('complejidadValue').textContent = metrics.complejidad + '%';
            document.getElementById('tendenciaValue').textContent = metrics.tendencia + '%';
            document.getElementById('riesgoValue').textContent = metrics.riesgo + '%';
            
            // Actualizar Hurst
            const hurst = 0.5 + (Math.random() * 0.3);
            document.getElementById('hurstValue').textContent = hurst.toFixed(2);
            const hurstType = hurst > 0.6 ? 'trending' : hurst < 0.4 ? 'meanreverting' : 'random';
            const hurstEl = document.getElementById('hurstType');
            hurstEl.className = `hurst-indicator hurst-${hurstType}`;
            hurstEl.innerHTML = hurstType === 'trending' ? '<i class="fas fa-arrow-trend-up"></i> Tendencial' : 
                                hurstType === 'meanreverting' ? '<i class="fas fa-arrows-left-right"></i> Reversivo' : 
                                '<i class="fas fa-shuffle"></i> Aleatorio';
            
            if (radarChart) radarChart.destroy();
            
            radarChart = new Chart(ctx, {
                type: 'radar',
