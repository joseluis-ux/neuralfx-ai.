<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuralFX.ai - Generador MQL4/MQL5 con Perfil de Bot IA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Orbitron:wght@400;500;600;700&display=swap');
        
        :root {
            --primary: #00d4ff;
            --secondary: #7000ff;
            --accent: #ff006e;
            --success: #00ff88;
            --warning: #ffb700;
            --danger: #ff3333;
            --dark: #050508;
            --panel: #0a0a0f;
        }
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background: #020203;
            color: #e0e0e0;
            overflow: hidden;
            height: 100vh;
        }
        
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        .font-tech { font-family: 'Orbitron', sans-serif; }
        
        .bg-grid {
            background-image: 
                linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
        }
        
        .glass {
            background: rgba(10, 10, 15, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .glass-panel {
            background: linear-gradient(145deg, rgba(15, 15, 25, 0.95), rgba(8, 8, 12, 0.98));
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 212, 255, 0.1);
        }
        
        .node-canvas {
            background: 
                radial-gradient(circle at 50% 50%, rgba(0, 212, 255, 0.02) 0%, transparent 70%),
                linear-gradient(0deg, transparent 24%, rgba(0, 212, 255, 0.015) 25%, rgba(0, 212, 255, 0.015) 26%, transparent 27%, transparent 74%, rgba(0, 212, 255, 0.015) 75%, rgba(0, 212, 255, 0.015) 76%, transparent 77%, transparent),
                linear-gradient(90deg, transparent 24%, rgba(0, 212, 255, 0.015) 25%, rgba(0, 212, 255, 0.015) 26%, transparent 27%, transparent 74%, rgba(0, 212, 255, 0.015) 75%, rgba(0, 212, 255, 0.015) 76%, transparent 77%, transparent);
            background-size: 100% 100%, 30px 30px, 30px 30px;
        }
        
        .mql-toggle {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 20px;
            padding: 4px;
            display: flex;
            gap: 4px;
        }
        
        .mql-option {
            padding: 6px 16px;
            border-radius: 16px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
            background: transparent;
            color: #6b7280;
        }
        
        .mql-option.active {
            background: linear-gradient(135deg, #00d4ff, #7000ff);
            color: white;
            box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
        }
        
        .node {
            position: absolute;
            min-width: 220px;
            background: linear-gradient(145deg, #0f1419, #0a0d12);
            border: 1px solid rgba(0, 212, 255, 0.25);
            border-radius: 12px;
            box-shadow: 
                0 10px 40px rgba(0, 0, 0, 0.6),
                inset 0 1px 0 rgba(255, 255, 255, 0.05),
                0 0 20px rgba(0, 212, 255, 0.05);
            transition: all 0.3s ease;
            cursor: move;
            z-index: 10;
        }
        
        .node:hover {
            border-color: rgba(0, 212, 255, 0.5);
            box-shadow: 
                0 15px 50px rgba(0, 0, 0, 0.7),
                0 0 30px rgba(0, 212, 255, 0.15);
            transform: translateY(-2px);
        }
        
        .node.selected {
            border-color: #00d4ff;
            box-shadow: 
                0 0 0 2px rgba(0, 212, 255, 0.3),
                0 20px 60px rgba(0, 212, 255, 0.2);
            z-index: 20;
        }
        
        .node-header {
            background: linear-gradient(90deg, rgba(0, 212, 255, 0.15), rgba(112, 0, 255, 0.08));
            padding: 12px 16px;
            border-radius: 12px 12px 0 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .node-body { padding: 14px; font-size: 0.8rem; }
        
        .node-port {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #0a0d12;
            border: 2px solid #00d4ff;
            position: absolute;
            cursor: crosshair;
            transition: all 0.2s;
            z-index: 30;
        }
        
        .node-port:hover {
            background: #00d4ff;
            transform: scale(1.3);
            box-shadow: 0 0 10px #00d4ff;
        }
        
        .node-port.input { left: -7px; }
        .node-port.output { right: -7px; }
        
        .port-label {
            position: absolute;
            font-size: 0.7rem;
            color: #6b7280;
            font-family: 'JetBrains Mono', monospace;
            pointer-events: none;
            background: rgba(0, 0, 0, 0.8);
            padding: 2px 6px;
            border-radius: 4px;
        }
        
        .connection-svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }
        
        .connection-path {
            fill: none;
            stroke: url(#gradient-connection);
            stroke-width: 2.5;
            opacity: 0.9;
        }
        
        .kimi-panel {
            background: linear-gradient(180deg, #0a0a0f 0%, #050508 100%);
            border-left: 1px solid rgba(112, 0, 255, 0.2);
        }
        
        .chat-message {
            max-width: 90%;
            padding: 12px 16px;
            border-radius: 12px;
            margin-bottom: 12px;
            font-size: 0.9rem;
            line-height: 1.5;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .chat-user {
            background: linear-gradient(135deg, rgba(0, 212, 255, 0.2), rgba(0, 212, 255, 0.1));
            border: 1px solid rgba(0, 212, 255, 0.3);
            margin-left: auto;
            border-bottom-right-radius: 4px;
        }
        
        .chat-kimi {
            background: linear-gradient(135deg, rgba(112, 0, 255, 0.2), rgba(112, 0, 255, 0.1));
            border: 1px solid rgba(112, 0, 255, 0.3);
            margin-right: auto;
            border-bottom-left-radius: 4px;
        }
        
        .palette-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 12px;
            cursor: grab;
            transition: all 0.2s;
            margin-bottom: 8px;
        }
        
        .palette-item:hover {
            background: rgba(0, 212, 255, 0.08);
            border-color: rgba(0, 212, 255, 0.3);
            transform: translateX(4px);
        }
        
        .palette-category {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 10px;
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
        }
        
        .param-input {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 12px;
            color: #e0e0e0;
            width: 100%;
            font-family: 'JetBrains Mono', monospace;
        }
        
        .param-input:focus {
            outline: none;
            border-color: #00d4ff;
            box-shadow: 0 0 0 2px rgba(0, 212, 255, 0.2);
        }
        
        .param-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        
        .param-label {
            font-size: 11px;
            color: #9ca3af;
        }
        
        .code-block {
            background: #0d1117;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 16px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            line-height: 1.6;
            overflow-x: auto;
            max-height: 400px;
            overflow-y: auto;
        }
        
        .code-keyword { color: #ff7b72; }
        .code-function { color: #d2a8ff; }
        .code-string { color: #a5d6ff; }
        .code-comment { color: #8b949e; }
        .code-number { color: #79c0ff; }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 500;
        }
        
        .status-badge.success {
            background: rgba(0, 255, 136, 0.1);
            border: 1px solid rgba(0, 255, 136, 0.3);
            color: #00ff88;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #00d4ff, #7000ff);
            border: none;
            border-radius: 8px;
            padding: 10px 20px;
            color: white;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 212, 255, 0.4);
        }
        
        .btn-secondary {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 10px 20px;
            color: #e0e0e0;
            font-weight: 500;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
        }
        
        .strategy-config {
            background: linear-gradient(145deg, rgba(15, 15, 25, 0.98), rgba(8, 8, 12, 0.99));
            border: 1px solid rgba(0, 212, 255, 0.15);
            border-radius: 12px;
            padding: 20px;
        }
        
        .config-section {
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .config-section:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        
        .section-title {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #00d4ff;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        /* Perfil del Bot - Radar Chart */
        .radar-container {
            position: relative;
            width: 200px;
            height: 200px;
            margin: 0 auto;
        }
        
        .metric-bar {
            height: 6px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            overflow: hidden;
            margin-top: 6px;
        }
        
        .metric-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }
        
        .hurst-indicator {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
        }
        
        .hurst-trending { background: rgba(0, 255, 136, 0.15); color: #00ff88; border: 1px solid rgba(0, 255, 136, 0.3); }
        .hurst-random { background: rgba(255, 193, 7, 0.15); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3); }
        .hurst-meanreverting { background: rgba(255, 107, 107, 0.15); color: #ff6b6b; border: 1px solid rgba(255, 107, 107, 0.3); }
        
        .prop-firm-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 140, 0, 0.15));
            border: 1px solid rgba(255, 215, 0, 0.4);
            border-radius: 20px;
            color: #ffd700;
            font-size: 11px;
            font-weight: 600;
        }
        
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0a0a0f; }
        ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #374151; }
    </style>
</head>
<body class="bg-grid h-screen flex flex-col">

    <!-- API Configuration Modal -->
    <div id="apiModal" class="fixed inset-0 bg-black/90 z-[100] flex items-center justify-center">
        <div class="glass-panel w-[500px] rounded-xl border border-yellow-500/30 p-6">
            <div class="flex items-center gap-3 mb-4">
                <i class="fas fa-key text-yellow-400 text-xl"></i>
                <h3 class="text-lg font-bold text-white">Configuración de API de IA</h3>
            </div>
            <p class="text-sm text-gray-400 mb-4">
                NeuralFX requiere una API key para generar estrategias con inteligencia artificial real.
                <span class="text-yellow-400">Tus credenciales se guardan solo en tu navegador (localStorage).</span>
            </p>
            
            <div class="space-y-3">
                <div>
                    <label class="text-xs text-gray-500 uppercase">Proveedor de IA</label>
                    <select id="apiProvider" class="w-full bg-gray-900 border border-gray-700 rounded p-2 text-sm text-white mt-1">
                        <option value="openai">OpenAI (GPT-4)</option>
                        <option value="gemini">Google Gemini</option>
                        <option value="anthropic">Anthropic Claude</option>
                        <option value="local">Modo Local (sin API)</option>
                    </select>
                </div>
                
                <div id="apiKeyContainer">
                    <label class="text-xs text-gray-500 uppercase">API Key</label>
                    <input type="password" id="apiKey" placeholder="sk-..." class="w-full bg-gray-900 border border-gray-700 rounded p-2 text-sm text-white mt-1 font-mono">
                </div>
                
                <div class="flex items-center gap-2 p-3 bg-yellow-500/10 border border-yellow-500/20 rounded">
                    <i class="fas fa-exclamation-triangle text-yellow-400"></i>
                    <span class="text-xs text-yellow-200">Nunca compartas tu API key. Se almacena localmente en tu dispositivo.</span>
                </div>
            </div>
            
            <button onclick="saveApiConfig()" class="w-full mt-4 bg-gradient-to-r from-cyan-600 to-purple-600 py-3 rounded-lg font-bold text-white hover:from-cyan-500 hover:to-purple-500 transition-all">
                Iniciar NeuralFX
            </button>
        </div>
    </div>

    <!-- Perfil del Bot Modal -->
    <div id="botProfileModal" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-[90] hidden flex items-center justify-center p-4">
        <div class="glass-panel w-[900px] max-h-[90vh] rounded-xl border border-cyan-500/20 overflow-hidden flex flex-col">
            <div class="p-6 border-b border-cyan-500/10 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500 to-purple-600 flex items-center justify-center">
                        <i class="fas fa-robot text-white text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white font-tech">Perfil del Bot</h3>
                        <p class="text-sm text-gray-400">Análisis multidimensional de tu estrategia</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="prop-firm-badge">
                        <i class="fas fa-trophy"></i>
                        Optimizado para Prop Firms
                    </span>
                    <button onclick="closeBotProfile()" class="p-2 rounded-lg hover:bg-white/10 text-gray-400 hover:text-white">
                        <i class="fas fa-times text-lg"></i>
                    </button>
                </div>
            </div>
            
            <div class="flex-1 overflow-y-auto p-6">
                <div class="grid grid-cols-3 gap-6">
                    <!-- Columna 1: Radar Chart -->
                    <div class="space-y-4">
                        <div class="glass-panel rounded-xl p-4 border border-purple-500/20">
                            <h4 class="text-sm font-semibold text-purple-400 mb-4 text-center">Perfil Visual</h4>
                            <div class="radar-container">
                                <canvas id="radarChart"></canvas>
                            </div>
                            <div class="mt-4 grid grid-cols-2 gap-2 text-xs">
                                <div class="text-center">
                                    <div class="text-gray-500">Robustez</div>
                                    <div class="text-cyan-400 font-bold" id="robustezValue">78%</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-gray-500">Complejidad</div>
                                    <div class="text-purple-400 font-bold" id="complejidadValue">65%</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-gray-500">Tendencia</div>
                                    <div class="text-emerald-400 font-bold" id="tendenciaValue">82%</div>
                                </div>
                                <div class="text-center">
                                    <div class="text-gray-500">Riesgo</div>
                                    <div class="text-orange-400 font-bold" id="riesgoValue">45%</div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Exponente de Hurst -->
                        <div class="glass-panel rounded-xl p-4 border border-cyan-500/20">
                            <h4 class="text-sm font-semibold text-cyan-400 mb-3">
                                <i class="fas fa-wave-square mr-2"></i>Exponente de Hurst
                            </h4>
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-2xl font-bold text-white" id="hurstValue">0.64</span>
                                <span class="hurst-indicator hurst-trending" id="hurstType">
                                    <i class="fas fa-arrow-trend-up"></i>
                                    Tendencial
                                </span>
                            </div>
                            <div class="metric-bar">
                                <div class="metric-fill bg-gradient-to-r from-red-500 via-yellow-500 to-green-500" style="width: 64%"></div>
                            </div>
                            <p class="text-xs text-gray-500 mt-2">Confianza: <span class="text-cyan-400">95%</span></p>
                            <p class="text-xs text-gray-400 mt-1">El mercado muestra persistencia en la dirección de la tendencia</p>
                        </div>
                    </div>
                    
                    <!-- Columna 2: Régimen de Mercado -->
                    <div class="space-y-4">
                        <div class="glass-panel rounded-xl p-4 border border-emerald-500/20">
                            <h4 class="text-sm font-semibold text-emerald-400 mb-4">
                                <i class="fas fa-chart-line mr-2"></i>Régimen de Mercado
                            </h4>
                            <div class="space-y-3">
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Seguimiento de Tendencia</span>
                                        <span class="text-emerald-400 font-mono">44/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-emerald-500" style="width: 44%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Reversión a la Media</span>
                                        <span class="text-orange-400 font-mono">32/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-orange-500" style="width: 32%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Ruptura</span>
                                        <span class="text-red-400 font-mono">15/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-red-500" style="width: 15%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Momentum</span>
                                        <span class="text-cyan-400 font-mono">60/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-cyan-500" style="width: 60%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Basado en Volatilidad</span>
                                        <span class="text-purple-400 font-mono">5/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-purple-500" style="width: 5%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Frecuencia Operativa -->
                        <div class="glass-panel rounded-xl p-4 border border-pink-500/20">
                            <h4 class="text-sm font-semibold text-pink-400 mb-4">
                                <i class="fas fa-clock mr-2"></i>Frecuencia Operativa
                            </h4>
                            <div class="space-y-3">
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Scalping (1-5 min)</span>
                                        <span class="text-red-400 font-mono">13/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-red-500" style="width: 13%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Intradía (15min-1H)</span>
                                        <span class="text-emerald-400 font-mono">85/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-emerald-500" style="width: 85%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div class="flex justify-between text-sm mb-1">
                                        <span class="text-gray-400">Swing (4H-Diario)</span>
                                        <span class="text-yellow-400 font-mono">45/100</span>
                                    </div>
                                    <div class="metric-bar">
                                        <div class="metric-fill bg-yellow-500" style="width: 45%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Columna 3: Compatibilidad -->
                    <div class="space-y-4">
                        <div class="glass-panel rounded-xl p-4 border border-yellow-500/20">
                            <h4 class="text-sm font-semibold text-yellow-400 mb-4">
                                <i class="fas fa-globe mr-2"></i>Compatibilidad de Mercado
                            </h4>
                            <div class="space-y-3">
