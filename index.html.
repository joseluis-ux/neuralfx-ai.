        function createNode(type, x, y, customParams = {}) {
            const def = nodeDefs[type];
            const id = `node-${nodeIdCounter++}`;
            
            const node = { id, type, x, y, params: { ...def.params, ...customParams } };
            nodes.push(node);
            
            const el = document.createElement('div');
            el.className = 'node';
            el.id = id;
            el.style.left = `${x}px`;
            el.style.top = `${y}px`;
            
            const colorMap = {
                blue: 'text-blue-400', purple: 'text-purple-400', cyan: 'text-cyan-400',
                pink: 'text-pink-400', emerald: 'text-emerald-400', red: 'text-red-400',
                green: 'text-green-400', orange: 'text-orange-400', amber: 'text-amber-400'
            };
            
            let paramsHtml = '';
            Object.entries(node.params).forEach(([key, value]) => {
                paramsHtml += `
                    <div class="param-row mt-2">
                        <span class="param-label text-[10px]">${key}</span>
                        <input type="text" class="param-input w-16 text-[10px]" value="${value}" 
                            onchange="updateNodeParam('${id}', '${key}', this.value)">
                    </div>
                `;
            });
            
            el.innerHTML = `
                <div class="node-header">
                    <i class="fas ${def.icon} ${colorMap[def.color]}"></i>
                    <span class="text-gray-200">${def.title}</span>
                </div>
                <div class="node-body">
                    ${paramsHtml}
                </div>
            `;
            
            def.inputs.forEach((input, i) => {
                const port = document.createElement('div');
                port.className = 'node-port input';
                port.style.top = `${50 + (i * 30)}px`;
                port.dataset.port = `in-${i}`;
                port.dataset.node = id;
                port.title = input;
                port.onmousedown = (e) => startConnection(e, id, `in-${i}`, 'input');
                
                const label = document.createElement('span');
                label.className = 'port-label';
                label.style.left = '20px';
                label.style.top = `${48 + (i * 30)}px`;
                label.textContent = input;
                
                el.appendChild(port);
                el.appendChild(label);
            });
            
            def.outputs.forEach((output, i) => {
                const port = document.createElement('div');
                port.className = 'node-port output';
                port.style.top = `${50 + (i * 30)}px`;
                port.dataset.port = `out-${i}`;
                port.dataset.node = id;
                port.title = output;
                port.onmousedown = (e) => startConnection(e, id, `out-${i}`, 'output');
                
                const label = document.createElement('span');
                label.className = 'port-label';
                label.style.right = '20px';
                label.style.top = `${48 + (i * 30)}px`;
                label.textContent = output;
                
                el.appendChild(port);
                el.appendChild(label);
            });
            
            el.onmousedown = (e) => {
                if (!e.target.classList.contains('node-port') && !e.target.classList.contains('param-input')) {
                    selectNode(id);
                    startDrag(e, id);
                }
            };
            
            document.getElementById('nodesLayer').appendChild(el);
            updateCounters();
            document.getElementById('emptyState').style.display = 'none';
            
            return node;
        }

        function updateNodeParam(nodeId, param, value) {
            const node = nodes.find(n => n.id === nodeId);
            if (node) {
                node.params[param] = isNaN(value) ? value : Number(value);
            }
        }

        function selectNode(id) {
            document.querySelectorAll('.node').forEach(n => n.classList.remove('selected'));
            document.getElementById(id)?.classList.add('selected');
            selectedNode = nodes.find(n => n.id === id);
        }

        function startDrag(e, id) {
            isDragging = true;
            const node = document.getElementById(id);
            const rect = node.getBoundingClientRect();
            dragOffset.x = e.clientX - rect.left;
            dragOffset.y = e.clientY - rect.top;
            
            const onMove = (e) => {
                if (!isDragging) return;
                const container = document.getElementById('canvasContainer');
                const contRect = container.getBoundingClientRect();
                
                const x = (e.clientX - contRect.left - dragOffset.x) / scale;
                const y = (e.clientY - contRect.top - dragOffset.y) / scale;
                
                const nodeData = nodes.find(n => n.id === id);
                nodeData.x = x;
                nodeData.y = y;
                node.style.left = `${x}px`;
                node.style.top = `${y}px`;
                updateConnections();
            };
            
            const onUp = () => {
                isDragging = false;
                document.removeEventListener('mousemove', onMove);
                document.removeEventListener('mouseup', onUp);
            };
            
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onUp);
        }

        function startConnection(e, nodeId, portId, type) {
            e.stopPropagation();
            isConnecting = true;
            connectStart = { node: nodeId, port: portId, type };
            
            const svg = document.getElementById('connectionLayer');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.id = 'temp-connection';
            path.setAttribute('class', 'connection-path');
            path.setAttribute('stroke-dasharray', '5,5');
            path.setAttribute('opacity', '0.5');
            svg.appendChild(path);
            
            const onMove = (e) => updateTempConnection(e);
            const onUp = (e) => {
                isConnecting = false;
                document.removeEventListener('mousemove', onMove);
                document.removeEventListener('mouseup', onUp);
                
                const temp = document.getElementById('temp-connection');
                if (temp) temp.remove();
                
                const target = document.elementFromPoint(e.clientX, e.clientY);
                if (target?.classList.contains('node-port')) {
                    const targetNode = target.dataset.node;
                    const targetPort = target.dataset.port;
                    const targetType = target.classList.contains('input') ? 'input' : 'output';
                    
                    if (targetType !== connectStart.type && targetNode !== connectStart.node) {
                        const from = connectStart.type === 'output' ? connectStart : { node: targetNode, port: targetPort };
                        const to = connectStart.type === 'input' ? connectStart : { node: targetNode, port: targetPort };
                        createConnection(from, to);
                    }
                }
            };
            
            document.addEventListener('mousemove', onMove);
            document.addEventListener('mouseup', onUp);
        }

        function updateTempConnection(e) {
            const path = document.getElementById('temp-connection');
            if (!path || !connectStart) return;
            
            const fromNode = document.getElementById(connectStart.node);
            const fromPort = fromNode.querySelector(`[data-port="${connectStart.port}"]`);
            const fromRect = fromPort.getBoundingClientRect();
            const contRect = document.getElementById('canvasContainer').getBoundingClientRect();
            
            const x1 = fromRect.left + fromRect.width/2 - contRect.left;
            const y1 = fromRect.top + fromRect.height/2 - contRect.top;
            const x2 = e.clientX - contRect.left;
            const y2 = e.clientY - contRect.top;
            
            path.setAttribute('d', `M ${x1} ${y1} C ${x1+50} ${y1}, ${x2-50} ${y2}, ${x2} ${y2}`);
        }

        function createConnection(from, to) {
            connections.push({ from, to });
            
            const svg = document.getElementById('connectionLayer');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.setAttribute('class', 'connection-path');
            
            const update = () => {
                const fNode = document.getElementById(from.node);
                const tNode = document.getElementById(to.node);
                if (!fNode || !tNode) return;
                
                const fPort = fNode.querySelector(`[data-port="${from.port}"]`);
                const tPort = tNode.querySelector(`[data-port="${to.port}"]`);
                if (!fPort || !tPort) return;
                
                const contRect = document.getElementById('canvasContainer').getBoundingClientRect();
                const fRect = fPort.getBoundingClientRect();
                const tRect = tPort.getBoundingClientRect();
                
                const x1 = fRect.left + fRect.width/2 - contRect.left;
                const y1 = fRect.top + fRect.height/2 - contRect.top;
                const x2 = tRect.left + tRect.width/2 - contRect.left;
                const y2 = tRect.top + tRect.height/2 - contRect.top;
                
                path.setAttribute('d', `M ${x1} ${y1} C ${x1+50} ${y1}, ${x2-50} ${y2}, ${x2} ${y2}`);
            };
            
            update();
            path.update = update;
            svg.appendChild(path);
            
            updateCounters();
        }

        function updateConnections() {
            document.querySelectorAll('.connection-path').forEach(p => {
                if (p.update) p.update();
            });
        }

        function zoomIn() { scale = Math.min(scale * 1.2, 3); applyZoom(); }
        function zoomOut() { scale = Math.max(scale / 1.2, 0.3); applyZoom(); }
        function resetZoom() { scale = 1; applyZoom(); }

        function applyZoom() {
            document.getElementById('nodesLayer').style.transform = `scale(${scale})`;
            document.getElementById('connectionLayer').style.transform = `scale(${scale})`;
            updateConnections();
        }

        function updateCounters() {
            document.getElementById('nodeCount').textContent = nodes.length;
            document.getElementById('connectionCount').textContent = connections.length;
        }

        // AI Functions
        function sendToAI() {
            const input = document.getElementById('kimiInput');
            const text = input.value.trim();
            if (!text) return;
            
            addChatMessage(text, 'user');
            input.value = '';
            
            const typing = document.createElement('div');
            typing.id = 'typing';
            typing.className = 'chat-message chat-kimi flex items-center gap-2';
            typing.innerHTML = '<i class="fas fa-circle-notch fa-spin text-purple-400"></i><span class="text-sm text-gray-400">Analizando...</span>';
            document.getElementById('chatContainer').appendChild(typing);
            
            setTimeout(() => {
                document.getElementById('typing')?.remove();
                processAICommand(text);
            }, 800);
        }

        function quickCommand(cmd) {
            document.getElementById('kimiInput').value = cmd;
            sendToAI();
        }

        function processAICommand(text) {
            const lower = text.toLowerCase();
            
            for (const [key, blueprint] of Object.entries(aiBlueprints)) {
                if (lower.includes(key)) {
                    addChatMessage(`🤖 <strong>${blueprint.name}</strong><br><span class="text-sm text-gray-400">${blueprint.description}</span>`, 'kimi');
                    buildFromBlueprint(blueprint);
                    return;
                }
            }
            
            addChatMessage(`💡 Estrategias disponibles:<br>• <strong>scalping</strong> - VWAP + Pattern Scalp<br>• <strong>tendencia</strong> - EMA 50/200<br>• <strong>reversión</strong> - Bollinger + RSI<br>• <strong>prop firm</strong> - Optimizado para challenges`, 'kimi');
        }

        function buildFromBlueprint(blueprint) {
            clearCanvas(true);
            const createdNodes = [];
            
            blueprint.nodes.forEach((n, index) => {
                setTimeout(() => {
                    const node = createNode(n.type, n.x, n.y, n.params);
                    createdNodes.push(node);
                    
                    if (index === blueprint.nodes.length - 1) {
                        setTimeout(() => {
                            blueprint.connections.forEach(conn => {
                                const fromNode = createdNodes[conn.from];
                                const toNode = createdNodes[conn.to];
                                if (fromNode && toNode) {
                                    createConnection(
                                        { node: fromNode.id, port: conn.fromPort },
                                        { node: toNode.id, port: conn.toPort }
                                    );
                                }
                            });
                            generateMQL();
                        }, 300);
                    }
                }, index * 150);
            });
        }

        function addChatMessage(html, sender) {
            const container = document.getElementById('chatContainer');
            const div = document.createElement('div');
            div.className = `chat-message chat-${sender}`;
            div.innerHTML = html;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        // MQL Generation
        function generateMQL() {
            const isMQL4 = mqlVersion === 'mql4';
            const lotSize = document.getElementById('paramLotSize').value;
            const magicNumber = document.getElementById('paramMagic').value;
            const slPips = document.getElementById('paramSL').value;
            const tpPips = document.getElementById('paramTP').value;
            const propMode = document.getElementById('paramPropMode').checked;
            const maxDaily = document.getElementById('paramDailyLoss').value;
            
            let code = isMQL4 ? 
                generateMQL4(lotSize, magicNumber, slPips, tpPips, propMode, maxDaily) : 
                generateMQL5(lotSize, magicNumber, slPips, tpPips, propMode, maxDaily);
            
            document.getElementById('codePreview').innerHTML = syntaxHighlight(code);
        }

        function generateMQL4(lotSize, magicNumber, sl, tp, propMode, maxDaily) {
            return `//+------------------------------------------------------------------+
//|                                       NeuralFX_Strategy.mq4      |
//|                        Copyright 2024, NeuralFX.ai               |
//|                                             https://neuralfx.ai  |
//+------------------------------------------------------------------+
#property copyright "Copyright 2024, NeuralFX.ai"
#property link      "https://neuralfx.ai"
#property version   "1.00"
#property strict

//--- Input Parameters
input double   InpLotSize = ${lotSize};
input int      InpMagicNumber = ${magicNumber};
input int      InpStopLoss = ${sl};
input int      InpTakeProfit = ${tp};
${propMode ? `input double   InpMaxDailyLoss = ${maxDaily};  // Prop Firm: Max Daily Loss %
input bool     InpPropFirmMode = true;` : ''}

//--- Indicator Handles
${nodes.filter(n => n.type === 'ma').map((n, i) => 
`int handleMA${i};
double bufferMA${i}[];`).join('\n')}

//--- Global Variables
datetime lastTradeTime = 0;
double dailyStartEquity = 0;
datetime currentDay = 0;

//+------------------------------------------------------------------+
int OnInit()
{
   ${nodes.filter(n => n.type === 'ma').map((n, i) => 
   `handleMA${i} = iMA(NULL, 0, ${n.params.period}, 0, ${n.params.method === 'EMA' ? 'MODE_EMA' : 'MODE_SMA'}, PRICE_CLOSE);
   if(handleMA${i} < 0) { Print("Error creating MA${i}"); return(INIT_FAILED); }`).join('\n   ')}
   
   dailyStartEquity = AccountBalance();
   currentDay = TimeCurrent() / 86400 * 86400;
   
   Print("NeuralFX Strategy initialized");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
void OnTick()
{
   //--- Prop Firm: Check Daily Loss Limit
   ${propMode ? `datetime today = TimeCurrent() / 86400 * 86400;
   if(today != currentDay)
   {
      dailyStartEquity = AccountBalance();
      currentDay = today;
   }
   
   double dailyPnL = (AccountBalance() - dailyStartEquity) / dailyStartEquity * 100;
   if(dailyPnL <= -InpMaxDailyLoss)
   {
      if(TimeCurrent() - lastTradeTime > 3600)  // Alert once per hour
      {
         Print("DAILY LOSS LIMIT REACHED: ", dailyPnL, "%");
         lastTradeTime = TimeCurrent();
      }
      return;  // Stop trading for the day
   }` : ''}
   
   //--- Check for new bar
   static datetime lastBar = 0;
   if(lastBar == Time[0]) return;
   lastBar = Time[0];
   
   //--- Copy indicator data
   ${nodes.filter(n => n.type === 'ma').map((n, i) => 
   `CopyBuffer(handleMA${i}, 0, 0, 3, bufferMA${i});
   double ma${i}Current = bufferMA${i}[0];
   double ma${i}Prev = bufferMA${i}[1];`).join('\n   ')}
   
   //--- Check positions
   bool hasLong = false;
   bool hasShort = false;
   
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
      {
         if(OrderMagicNumber() == InpMagicNumber && OrderSymbol() == Symbol())
         {
            if(OrderType() == OP_BUY) hasLong = true;
            if(OrderType() == OP_SELL) hasShort = true;
         }
      }
   }
   
   //--- Generate signals
   bool buySignal = false;
   bool sellSignal = false;
   
   ${generateSignalLogic()}
   
   //--- Execute trades
   if(buySignal && !hasLong)
   {
      CloseAllShorts();
      double sl = InpStopLoss > 0 ? Ask - InpStopLoss * Point : 0;
      double tp = InpTakeProfit > 0 ? Ask + InpTakeProfit * Point : 0;
      int ticket = OrderSend(Symbol(), OP_BUY, InpLotSize, Ask, 3, sl, tp, "NeuralFX Buy", InpMagicNumber, 0, clrGreen);
      if(ticket > 0) lastTradeTime = TimeCurrent();
   }
   
   if(sellSignal && !hasShort)
   {
      CloseAllLongs();
      double sl = InpStopLoss > 0 ? Bid + InpStopLoss * Point : 0;
      double tp = InpTakeProfit > 0 ? Bid - InpTakeProfit * Point : 0;
      int ticket = OrderSend(Symbol(), OP_SELL, InpLotSize, Bid, 3, sl, tp, "NeuralFX Sell", InpMagicNumber, 0, clrRed);
      if(ticket > 0) lastTradeTime = TimeCurrent();
   }
}

//+------------------------------------------------------------------+
void CloseAllLongs()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
      {
         if(OrderMagicNumber() == InpMagicNumber && OrderSymbol() == Symbol() && OrderType() == OP_BUY)
            OrderClose(OrderTicket(), OrderLots(), Bid, 3, clrWhite);
      }
   }
}

//+------------------------------------------------------------------+
void CloseAllShorts()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      if(OrderSelect(i, SELECT_BY_POS, MODE_TRADES))
      {
         if(OrderMagicNumber() == InpMagicNumber && OrderSymbol() == Symbol() && OrderType() == OP_SELL)
            OrderClose(OrderTicket(), OrderLots(), Ask, 3, clrWhite);
      }
   }
}`;
        }

        function generateMQL5(lotSize, magicNumber, sl, tp, propMode, maxDaily) {
            return `//+------------------------------------------------------------------+
//|                                       NeuralFX_Strategy.mq5      |
//|                        Copyright 2024, NeuralFX.ai               |
//|                                             https://neuralfx.ai  |
//+------------------------------------------------------------------+
#property copyright "Copyright 2024, NeuralFX.ai"
#property link      "https://neuralfx.ai"
#property version   "1.00"

#include <Trade\\Trade.mqh>
#include <Trade\\PositionInfo.mqh>

//--- Input Parameters
input group "=== Trading Settings ==="
input double   InpLotSize = ${lotSize};
input int      InpMagicNumber = ${magicNumber};
input int      InpStopLoss = ${sl};
input int      InpTakeProfit = ${tp};

input group "=== Prop Firm Settings ==="
${propMode ? `input bool     InpPropFirmMode = true;
input double   InpMaxDailyLoss = ${maxDaily};
input double   InpMaxTotalLoss = 6.0;
input double   InpProfitTarget = 8.0;
input int      InpMinTradingDays = 5;` : ''}

//--- Trading Objects
CTrade trade;
CPositionInfo positionInfo;

//--- Strategy Variables
double dailyStartEquity = 0;
datetime currentDay = 0;
int tradingDays = 0;

//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(10);
   trade.SetTypeFilling(ORDER_FILLING_IOC);
   
   dailyStartEquity = AccountInfoDouble(ACCOUNT_BALANCE);
   currentDay = TimeCurrent() / 86400 * 86400;
   
   Print("NeuralFX Strategy initialized on ", _Symbol);
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
void OnTick()
{
   //--- Prop Firm Risk Management
   ${propMode ? `datetime today = TimeCurrent() / 86400 * 86400;
   if(today != currentDay)
   {
      if(AccountInfoDouble(ACCOUNT_BALANCE) != dailyStartEquity) tradingDays++;
      dailyStartEquity = AccountInfoDouble(ACCOUNT_BALANCE);
      currentDay = today;
   }
   
   double dailyPnL = (AccountInfoDouble(ACCOUNT_BALANCE) - dailyStartEquity) / dailyStartEquity * 100;
   double totalPnL = (AccountInfoDouble(ACCOUNT_BALANCE) - AccountInfoDouble(ACCOUNT_EQUITY)) / AccountInfoDouble(ACCOUNT_BALANCE) * 100;
   
   // Check daily loss limit
   if(dailyPnL <= -InpMaxDailyLoss)
   {
      Print("PROP FIRM: Daily loss limit reached: ", dailyPnL, "%");
      CloseAllPositions();
      return;
   }
   
   // Check total loss limit
   if(totalPnL <= -InpMaxTotalLoss)
   {
      Print("PROP FIRM: Total loss limit reached: ", totalPnL, "%");
      CloseAllPositions();
      ExpertRemove();
      return;
   }` : ''}
   
   //--- Check for new bar
   static datetime lastBar = 0;
   datetime currentBar = iTime(_Symbol, PERIOD_CURRENT, 0);
   if(lastBar == currentBar) return;
   lastBar = currentBar;
   
   MqlTick tick;
   if(!SymbolInfoTick(_Symbol, tick)) return;
   
   //--- Check positions
   bool hasLong = PositionSelect(_Symbol) && PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY;
   bool hasShort = PositionSelect(_Symbol) && PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_SELL;
   
   //--- Generate signals
   bool buySignal = false;
   bool sellSignal = false;
   
   ${generateSignalLogic()}
   
   //--- Execute trades
   if(buySignal && !hasLong)
   {
      trade.PositionClose(_Symbol);
      double slPrice = InpStopLoss > 0 ? NormalizeDouble(tick.ask - InpStopLoss * _Point, _Digits) : 0;
      double tpPrice = InpTakeProfit > 0 ? NormalizeDouble(tick.ask + InpTakeProfit * _Point, _Digits) : 0;
      
      if(trade.Buy(InpLotSize, _Symbol, tick.ask, slPrice, tpPrice, "NeuralFX Buy"))
         SendNotification("🟢 BUY " + _Symbol + " @ " + DoubleToString(tick.ask, _Digits));
   }
   
   if(sellSignal && !hasShort)
   {
      trade.PositionClose(_Symbol);
      double slPrice = InpStopLoss > 0 ? NormalizeDouble(tick.bid + InpStopLoss * _Point, _Digits) : 0;
      double tpPrice = InpTakeProfit > 0 ? NormalizeDouble(tick.bid - InpTakeProfit * _Point, _Digits) : 0;
      
      if(trade.Sell(InpLotSize, _Symbol, tick.bid, slPrice, tpPrice, "NeuralFX Sell"))
         SendNotification("🔴 SELL " + _Symbol + " @ " + DoubleToString(tick.bid, _Digits));
   }
}

//+------------------------------------------------------------------+
void CloseAllPositions()
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetSymbol(i) == _Symbol)
         trade.PositionClose(_Symbol);
   }
}`;
        }

        function generateSignalLogic() {
            const maNodes = nodes.filter(n => n.type === 'ma');
            const rsiNodes = nodes.filter(n => n.type === 'rsi');
            
            if (maNodes.length >= 2) {
                return `//--- MA Cross strategy
   if(ma0Current > ma1Current && ma0Prev <= ma1Prev) buySignal = true;
   if(ma0Current < ma1Current && ma0Prev >= ma1Prev) sellSignal = true;`;
            } else if (rsiNodes.length > 0) {
                return `//--- RSI Reversal strategy
   if(rsi0 < 30) buySignal = true;
   if(rsi0 > 70) sellSignal = true;`;
            }
            
            return `//--- Default strategy
   buySignal = (Close[0] > Open[0]);
   sellSignal = (Close[0] < Open[0]);`;
        }

        function syntaxHighlight(code) {
            return code
                .replace(/\/\/.*/g, '<span class="code-comment">$&</span>')
                .replace(/\b(int|double|bool|string|void|return|if|else|for|while|input|static|const|enum)\b/g, '<span class="code-keyword">$1</span>')
                .replace(/\b(Print|OrderSend|OrderClose|PositionClose|CopyBuffer|iMA|iRSI|NormalizeDouble|SendNotification)\b/g, '<span class="code-function">$1</span>')
                .replace(/".*?"/g, '<span class="code-string">$&</span>')
                .replace(/\b\d+\.?\d*\b/g, '<span class="code-number">$&</span>');
        }

        function downloadCode() {
            const code = document.getElementById('codePreview').innerText;
            const extension = mqlVersion === 'mql4' ? '.mq4' : '.mq5';
            const blob = new Blob([code], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `NeuralFX_Strategy${extension}`;
            a.click();
        }

        function compileStrategy() {
            showToast('🔨 Compilando...');
            setTimeout(() => {
                showToast('✅ Compilación exitosa. 0 errores, 0 advertencias.');
            }, 2000);
        }

        function clearCanvas(skipConfirm = false) {
            if (!skipConfirm && !confirm('¿Eliminar todos los nodos?')) return;
            nodes = [];
            connections = [];
            document.getElementById('nodesLayer').innerHTML = '';
            document.querySelectorAll('.connection-path').forEach(p => { if (p.id !== 'temp-connection') p.remove(); });
            document.getElementById('emptyState').style.display = 'flex';
            updateCounters();
        }

        function showToast(msg) {
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-4 right-4 glass px-6 py-3 rounded-lg border border-cyan-500/30 text-white z-50 animate-slideIn';
            toast.innerHTML = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // Init
        window.onload = () => {
            loadApiConfig();
            generateMQL();
        };
    </script>
</body>
